# 1) Riot API 키
#    https://developer.riotgames.com 로그인 → "DEVELOPMENT API KEY" 복사
#    ⚠️ 개발 키는 24시간마다 만료 → 매일 재발급 필요
#    프로덕션 준비되면 "PERSONAL/PRODUCTION KEY" 신청
RIOT_API_KEY=RGAPI-5b1ffba9-f528-450b-8c42-d5a5c5654d6e

# 2) 플랫폼 (한국 서버면 그대로 둬도 됨)
RIOT_PLATFORM=kr       # 리그/소환사 조회용
RIOT_REGION=asia       # 매치 데이터 조회용

# 3) Supabase DB 연결 문자열
#    Supabase 대시보드 → Settings → Database → Connection string
#    "Session mode" 탭의 URI 복사 (포트 5432)
#    ⚠️ Transaction mode(6543)는 sqlx와 궁합이 안 좋음 → 5432 쓸 것
DATABASE_URL=postgresql://postgres.qnblyolhffueodtgcyia:Psso30203@.@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# 4) 서버 바인드 (로컬 개발이면 그대로)
BIND_ADDR=0.0.0.0:8080

RUST_LOG=debug,tft_iq=debug